# Django Environment Configuration
# Copy this file to .env and update with your actual values

# Environment (development or production)
DJANGO_ENVIRONMENT=development

# Django Core Settings
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Development (SQLite)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# Production (PostgreSQL) - uncomment and configure for production
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=elifwol_db
# DB_USER=elifwol_user
# DB_PASSWORD=your-secure-password
# DB_HOST=localhost
# DB_PORT=5432
# DB_CONN_MAX_AGE=600

# URLs
BASE_URL=http://127.0.0.1:8000
STATIC_URL=/static/
MEDIA_URL=/media/

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.mailgun.org
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@elifwol.com

# Mailgun API (if used)
MAILGUN_API_ID=
MAILGUN_API_KEY=

# Security Settings (Production)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Logging
DJANGO_LOG_LEVEL=INFO
LOG_FILE_PATH=logs/django.log

# Admin Configuration
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@elifwol.com

# Cache Configuration (Production - Redis)
# CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
# REDIS_URL=redis://127.0.0.1:6379/1

# CORS Settings (if needed)
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Internationalization
LANGUAGE_CODE=en-us
TIME_ZONE=UTC

# Session Configuration
SESSION_COOKIE_AGE=1209600
