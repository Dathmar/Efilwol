# Python
*.py[cod]
*$py.class
*.so
.Python
__pycache__/
*.egg-info/
dist/
build/
.venv/
venv/
ENV/
env/

# Django
*.log
db.sqlite3
db.sqlite3-journal
/media
/staticfiles
local_settings.py
Efilwol/settings.py.backup

# Logs directory (keep directory, ignore contents)
logs/*
!logs/.gitkeep

# Environment files (keep .env.example only — never commit real env files)
.env
.env.local
.env.development
.env.production
.env.*.local
!.env.example

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Tailwind CSS
base/static/css/output.css

# Vendored static libraries — install via npm/CDN, don't commit
base/static/bootstrap/

# Font files — large binaries, serve via CDN or npm in production
# Remove this line if you want fonts tracked in git
base/static/fonts/

# Client/business documents — not source code
base/static/assets/*.pdf

# Scratch / ad-hoc files
docs/scratch/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
